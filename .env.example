# Environment Variables
# Copy this file to .env and fill in your actual values

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/login_portal

# Express Session Secret
SESSION_SECRET=your_super_secret_session_key_change_in_production

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Bind host/address
# Use 0.0.0.0 on AWS to accept public incoming traffic
# Use 127.0.0.1 in production when using nginx reverse proxy
HOST=0.0.0.0

# Database Name
DB_NAME=login_portal

# HTTPS/SSL Configuration
# Set to 'true' when using nginx as reverse proxy with SSL/TLS
TRUST_PROXY=false

# SSL Certificates (only needed if running HTTPS directly in Node.js)
# Not required when using nginx reverse proxy with Let's Encrypt
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem
# SSL_KEY_PATH=/etc/ssl/private/key.pem

# Production Configuration Template (uncomment when deploying)
# NODE_ENV=production
# HOST=127.0.0.1
# TRUST_PROXY=true
